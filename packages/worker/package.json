{
  "name": "worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.jsonc",
    "deploy": "wrangler deploy --config wrangler.jsonc",
    "db:local": "wrangler d1 execute edge-mail-db --local --file=schema.sql",
    "types": "wrangler types",
    "test": "vitest run",
    "db:export:local": "bash scripts/db-export.sh local",
    "db:export:remote": "bash scripts/db-export.sh remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250415.0",
    "@types/node": "^25.8.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.15.0"
  },
  "dependencies": {
    "hono": "^4.12.18",
    "postal-mime": "^2.4.0"
  }
}
